@prefix : <http://example.org/leonardo#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:LeonardoOntology a owl:Ontology .

########################
# CORE CLASSES
########################

:Student a owl:Class .

:Activity a owl:Class .
:Course a owl:Class ;
    rdfs:subClassOf :Activity .
:Project a owl:Class ;
    rdfs:subClassOf :Activity .

:Participation a owl:Class .

:SurveyCompilation a owl:Class .
:PsyCompilation a owl:Class ;
    rdfs:subClassOf :SurveyCompilation .
:ObjCompilation a owl:Class ;
    rdfs:subClassOf :SurveyCompilation .

:SurveyResult a owl:Class .

:SurveyDimension a owl:Class .

########################
# LEVEL MODEL
########################

:Level a owl:Class .

:Level1 a :Level .
:Level2 a :Level .
:Level3 a :Level .
:Level4 a :Level .

########################
# OBJECT PROPERTIES
########################

:participatesIn a owl:ObjectProperty ;
    rdfs:domain :Participation ;
    rdfs:range :Activity .

:participant a owl:ObjectProperty ;
    rdfs:domain :Participation ;
    rdfs:range :Student .

:worksAt a owl:ObjectPropery ;
    rdfs:domain :Student ;
    rdfs:range :Project .

:hasLevel a owl:ObjectProperty ;
    rdfs:range :Level .

:compiledBy a owl:ObjectProperty ;
    rdfs:domain :SurveyCompilation ;
    rdfs:range :Student .

:hasResult a owl:ObjectProperty ;
    rdfs:domain :SurveyCompilation ;
    rdfs:range :SurveyResult .

:measures a owl:ObjectProperty ;
    rdfs:domain :SurveyResult ;
    rdfs:range :SurveyDimension .

########################
# DATATYPE PROPERTIES
########################

:name a owl:DatatypeProperty ;
    rdfs:range xsd:string .

:degree a owl:DatatypeProperty ;
    rdfs:domain :Student ;
    rdfs:range xsd:string .

:year a owl:DatatypeProperty ;
    rdfs:range xsd:integer .

:semester a owl:DatatypeProperty ;
    rdfs:range xsd:integer .

:score a owl:DatatypeProperty ;
    rdfs:domain :SurveyResult ;
    rdfs:range xsd:decimal .