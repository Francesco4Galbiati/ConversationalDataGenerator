        ex:event_EV007,
        ex:event_EV011,
        ex:event_EV015,
        ex:event_EV017,
        ex:event_EV023,
        ex:event_EV040,
        ex:event_EV045 ;
    ns1:troubleTicketCause "Database corruption leading to service interruption",
        "Memory leak in application leading to intermittent crashes",
