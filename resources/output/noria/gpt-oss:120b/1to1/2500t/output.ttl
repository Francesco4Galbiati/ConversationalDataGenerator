        ex:resource_RES001 ;
    ns1:notes "Issue resolved by replacing the router and restoring connectivity.",
        "Resolved by applying database patches and restoring affected data",
        "Resolved by applying memory usage patches and restarting services, then monitoring for stability.",
        "Resolved by correcting firewall settings and validating traffic flow" ;
    ns1:problemCategory "API Rate Limiting",
        "Capacity Planning Issue",
        "Configuration Error",
        "Database Corruption",
