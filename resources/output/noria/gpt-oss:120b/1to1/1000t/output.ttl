ex:action_ACT001 a ns1:ProcedureExecution ;
    ns1:description "Replaced the faulty network switch, applied the latest firmware update, and verified connectivity." ;
    ns1:madeBy ex:agent_AGT001 ;
    ns1:operationPlanPostCondition "ACT001 aims to eliminate the malfunction and reestablish stable, regular system performance.",
