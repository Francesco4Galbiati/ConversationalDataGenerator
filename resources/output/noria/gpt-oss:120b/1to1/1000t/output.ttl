    ns1:description "Isolate affected subsystem, apply security patch, and perform integrity verification." ;
    ns1:operationPlanPostCondition "Restores system stability, eliminates vulnerability, and returns operations to normal." .

ex:plan_OPL003 a ns1:OperationPlan ;
    ns1:description "Quarantine affected module, run forensic analysis, and implement corrective configuration update." ;
    ns1:operationPlanPostCondition "System returns to normal operation with no residual threats." .

ex:plan_OPL004 a ns1:OperationPlan ;
    ns1:description "Deploy emergency response team to isolate the compromised node, apply security patch, and verify system integrity." ;
    ns1:operationPlanPostCondition "Compromised node isolated, vulnerability mitigated, and system restored to normal operation." .

ex:plan_OPL005 a ns1:OperationPlan ;
    ns1:description "Activate emergency response, isolate compromised node, apply latest security patch, and verify system integrity." ;
    ns1:operationPlanPostCondition "Compromised node isolated, vulnerability patched, and system integrity restored." .

ex:plan_OPL006 a ns1:OperationPlan ;
